    {
      "parameters": {
        "jsCode": "// 1. Lecture des variables d'environnement Docker\n// ATTENTION : On utilise le nom défini dans le docker-compose pour n8n\nconst backendUrl = $env[\"BACKEND_API_URL\"]; \nconst aiUrl = $env[\"AI_SERVICE_URL\"];\nconst token = $env[\"BACKEND_API_TOKEN\"];\n\n// 2. Récupération des données du Webhook\nconst body = $node[\"Webhook - Application Submitted\"].json.body;\n\nreturn {\n  // Config pour l'appel IA\n  ai_request: {\n    url: `${aiUrl}/api/match-score`,\n    payload: {\n      candidate_id: body.candidateId,\n      job_offer_id: body.jobOfferId\n    }\n  },\n  \n  // Config pour les appels Backend (Status Update)\n  backend_request: {\n    url: `${backendUrl}/api/applications/${body.applicationId}/status`,\n    auth_header: `Bearer ${token}`\n  },\n  \n  // Données pour les emails\n  email_data: {\n    candidate_name: body.candidateName,\n    candidate_email: body.candidateEmail,\n    job_title: body.jobTitle\n  }\n};"
      },
