# ===================================================
# RecruForce2 N8N Workflows - Environment Variables
# Full configuration for production
# ===================================================

# ============================================
# N8N BASIC AUTH
# ============================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin@recruforce2.com
N8N_BASIC_AUTH_PASSWORD=recruforce2_secure_password_2024

# ============================================
# N8N HOST CONFIGURATION
# ============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# For production (with domain)
# N8N_HOST=workflows.recruforce2.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://workflows.recruforce2.com

# ============================================
# N8N DATABASE (PostgreSQL)
# ============================================
N8N_DATABASE=n8n
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=n8n_secure_password_2024

# Database connection string (used by N8N)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=n8n_secure_password_2024

# ============================================
# N8N SECURITY
# ============================================
# Generate a random key with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=your-random-32-character-encryption-key-here-change-this

# ============================================
# BACKEND API (Spring Boot)
# ============================================
BACKEND_API_URL=http://host.docker.internal:8080
BACKEND_API_TOKEN=eyJhbGciOiJIUzM4NCJ9.eyJyb2xlIjoiQURNSU4iLCJ0eXBlIjoic2VydmljZSIsInN1YiI6Im44bi1zZXJ2aWNlQHJlY3J1Zm9yY2UyLmNvbSIsImlhdCI6MTc3MzgwMDU4NCwiZXhwIjoxNzgxNTc2NTg0fQ.fSxEQGvvLyiuWeIKuty9G9zOM5Hpo_7GF_jqfhhr7-3D4w4lYSJYaej1wRl7vbCT

# For production (backend on remote server)
# BACKEND_API_URL=https://api.recruforce2.com

# ============================================
# AI SERVICE (Python FastAPI)
# ============================================
AI_SERVICE_URL=http://host.docker.internal:8000

# For production
# AI_SERVICE_URL=https://ai.recruforce2.com

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
# Gmail SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=amdymoustapha011@gmail.com
SMTP_PASS=bxrbmyupumvsdlgq  
SMTP_FROM="RecruForce2 <noreply@recruforce2.com>"

# Other SMTP providers (uncomment if needed)

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASSWORD=your-mailgun-password

# Office365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@company.com
# SMTP_PASSWORD=your-password

# ============================================
# LINKEDIN API (OPTIONAL)
# ============================================
LINKEDIN_ENABLED=false
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_COMPANY_ID=your-linkedin-company-id

# To obtain LinkedIn credentials:
# 1. https://www.linkedin.com/developers/apps
# 2. Create an app
# 3. Request access to "Marketing Developer Platform"
# 4. Generate an access token

# ============================================
# WEBHOOK URLs (for backend configuration)
# ============================================
WEBHOOK_CV_PARSING=http://localhost:5678/webhook/cv-parsing
WEBHOOK_APPLICATION=http://localhost:5678/webhook/application
WEBHOOK_JOB_POSTING=http://localhost:5678/webhook/job-posting
WEBHOOK_NOTIFICATION=http://localhost:5678/webhook/notification
WEBHOOK_INTERVIEW_REMINDER=http://localhost:5678/webhook/interview-reminder

# For production
# WEBHOOK_CV_PARSING=https://workflows.recruforce2.com/webhook/cv-parsing
# etc.

# ============================================
# N8N EXECUTION SETTINGS
# ============================================
EXECUTIONS_MODE=regular
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true

# ============================================
# TIMEZONE
# ============================================
TZ=Europe/Paris
GENERIC_TIMEZONE=Europe/Paris

# ============================================
# N8N PERFORMANCE
# ============================================
# Number of workers (recommended: number of CPU cores)
N8N_CONCURRENCY_PRODUCTION_LIMIT=10

# ============================================
# LOGGING
# ============================================
N8N_LOG_LEVEL=info
# Options: error, warn, info, verbose, debug

# ============================================
# CREDENTIALS ENCRYPTION
# ============================================
# IMPORTANT: Change this key in production
CREDENTIALS_OVERWRITE_ENDPOINT=http://localhost:5678/

# ============================================
# DEVELOPMENT vs PRODUCTION
# ============================================
NODE_ENV=production
# For development: NODE_ENV=development

# ============================================
# HEALTHCHECK
# ============================================
N8N_METRICS=true
N8N_METRICS_PREFIX=n8n_

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. GMAIL APP PASSWORD:
#    - Go to https://myaccount.google.com/apppasswords
#    - Create an "App Password" for N8N
#    - Use this password (16 characters) in SMTP_PASSWORD
#
# 2. ENCRYPTION KEY:
#    - Generate with: openssl rand -base64 32
#    - NEVER change in production (you will lose credentials)
#
# 3. BACKEND/AI URLs:
#    - In Docker: use host.docker.internal
#    - In production: use real domains
#
# 4. SECURITY:
#    - Change ALL default passwords
#    - Use HTTPS in production
#    - NEVER commit this file to Git (.gitignore)

